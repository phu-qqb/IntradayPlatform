{
  "ConnectionStrings": {
    "IntradaySqlServer": "Server=(localdb)\\MSSQLLocalDB;Database=QQProductionIntraday;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Persistence": {
    "Provider": "SqlServerLocal"
  },
  "Database": {
    "ApplyMigrationsOnStartup": false,
    "SeedReferenceDataOnStartup": true,
    "SeedDemoDataOnStartup": false
  },
  "Safety": {
    "AllowExternalConnections": false,
    "AllowLiveTrading": false,
    "RequireFakeExecutionGateway": true
  },
  "LmaxShadowReader": {
    "Enabled": false,
    "AllowExternalConnections": false,
    "AllowCredentialUse": false,
    "ReadOnly": true,
    "AllowOrderSubmission": false,
    "PersistRawFixMessages": false,
    "PersistToTradingTables": false,
    "MaxEventsPerRun": 25,
    "DryRun": true
  },
  "ReferenceDataIntegrity": {
    "CheckOnStartup": true,
    "FailStartupOnBlockingIssues": true
  },
  "LmaxEodReports": {
    "TimestampTimeZone": "UTC",
    "WalletBalanceTolerance": 0.01,
    "SummaryTolerance": 0.01,
    "DataRoot": "data/lmax-eod"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [ { "Name": "Console" } ]
  }
}
